{
  "name": "portosaur",
  "description": "Complete portfolio cum personal website solution for your digital personality",
  "version": "0.1.1",
  "license": "GPL-3.0-only",
  "private": true,
  "homepage": "https://soymadip.github.io/portosaur",
  "repository": {
    "type": "git",
    "url": "https://github.com/soymadip/portosaur"
  },
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "scripts": {
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "test:cli": "bun test --cwd packages/cli",
    "test:core": "bun test --cwd packages/core",
    "test:logger": "bun test --cwd packages/logger",
    "test:all": "bun test && bun run test:cli && bun run test:core && bun run test:logger",
    "build:docs": "bun run --cwd docs build",
    "build:all": "bun run build:docs",
    "dev": "bun run --cwd docs dev",
    "dev:docs": "bun run --cwd docs dev"
  },
  "devDependencies": {
    "prettier": "latest"
  },
  "engines": {
    "node": ">=24.15.0"
  }
}
