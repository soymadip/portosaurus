{
  "name": "portosaurus",
  "version": "1.18.15",
  "author": "soymadip",
  "license": "GPL-3.0-only",
  "description": "Complete portfolio cum personal website solution for your digital personality.",
  "homepage": "https://github.com/soymadip/portosaurus#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soymadip/portosaurus.git"
  },
  "bugs": {
    "url": "https://github.com/soymadip/portosaurus/issues"
  },
  "keywords": [
    "portfolio",
    "docusaurus",
    "cli",
    "static-site-generator",
    "documentation",
    "blog"
  ],
  "type": "module",
  "imports": {
    "#config/*": "./src/config/*",
    "#utils/*": "./src/utils/*.js",
    "#css/*": "./src/css/*.css",
    "#pages/*": "./src/pages/*.js",
    "#components/*": "./src/components/*",
    "#internal/*": "./src/internal/src/*"
  },
  "exports": {
    "./components/*": "./src/components/*",
    "./utils/*": "./src/utils/*.js",
    "./config/*": "./src/config/*.js",
    "./css/*": "./src/css/*.css",
    "./pages/*": "./src/pages/*.js"
  },
  "bin": {
    "portosaurus": "bin/portosaurus.js"
  },
  "files": [
    "bin/",
    "src/internal/",
    "src/template/",
    "src/utils/",
    "src/config/",
    "src/css/",
    "src/img",
    "src/pages/",
    "src/components/"
  ],
  "dependencies": {
    "@docusaurus/core": "^3.9.2",
    "@docusaurus/preset-classic": "^3.9.2",
    "@easyops-cn/docusaurus-search-local": "^0.52.3",
    "chalk": "^5.6.2",
    "clsx": "^2.1.1",
    "commander": "^12.1.0",
    "favicons": "^7.2.0",
    "fs-extra": "^11.3.3",
    "plugin-image-zoom": "github:flexanalytics/plugin-image-zoom",
    "prism-react-renderer": "^2.4.1",
    "prompts": "^2.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "react-slick": "^0.30.3",
    "slick-carousel": "^1.8.1"
  }
}
