{
  "name": "@portosaur/cli",
  "version": "0.1.1",
  "description": "CLI for Portosaur - The static Personal portfolio site generator.",
  "license": "GPL-3.0-only",
  "author": "soymadip",
  "homepage": "https://soymadip.github.io/portosaur",
  "repository": {
    "type": "git",
